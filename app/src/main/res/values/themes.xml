<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Light only -->
    <style name="Base.Theme.FlavourBasedBuildTest" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialButtonStyle">@style/AppButton</item>
        <item name="materialCardViewStyle">@style/AppCard</item>
    </style>

    <style name="Theme.FlavourBasedBuildTest" parent="Base.Theme.FlavourBasedBuildTest" />
    
    <!-- Dev Theme -->
    <style name="Theme.FlavourBasedBuildTest.Dev" parent="Base.Theme.FlavourBasedBuildTest">
        <item name="colorPrimary">@color/dev_primary</item>
        <item name="android:colorBackground">@color/dev_background</item>
        <item name="android:windowBackground">@color/dev_background</item>
    </style>
    
    <!-- Staging Theme -->
    <style name="Theme.FlavourBasedBuildTest.Staging" parent="Base.Theme.FlavourBasedBuildTest">
        <item name="colorPrimary">@color/staging_primary</item>
        <item name="android:colorBackground">@color/staging_background</item>
        <item name="android:windowBackground">@color/staging_background</item>
    </style>
    
    <!-- Prod Theme -->
    <style name="Theme.FlavourBasedBuildTest.Prod" parent="Base.Theme.FlavourBasedBuildTest">
        <item name="colorPrimary">@color/prod_primary</item>
        <item name="android:colorBackground">@color/prod_background</item>
        <item name="android:windowBackground">@color/prod_background</item>
    </style>
    
    <!-- Button Styles -->
    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:elevation">2dp</item>
    </style>
    
    <style name="AppButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <style name="AppButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    
    <!-- Card Styles -->
    <style name="AppCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextAppearance.Heading" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Subheading" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
    </style>
    
    <!-- Dialog Styles -->
    <style name="AppDialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="AppDialog.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="AppDialog.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>