default_platform(:android)

platform :android do
  desc "Build and deploy to Play Store - Internal Testing"
  lane :deploy_internal do
    json_key_path = ENV["PLAY_JSON_KEY_PATH"] || "play-store-service-account.json"
    json_key_content = File.read(json_key_path) if File.exist?(json_key_path)
    
    upload_to_play_store(
      aab: "app/build/outputs/bundle/prodRelease/app-prod-release.aab",
      track: "internal",
      json_key: json_key_content,
      package_name: "com.ext.flavourbasedbuildtest",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed",
      changelog: ENV["CHANGELOG"] || "Automated release from CI/CD pipeline"
    )
  end

  desc "Build and deploy to Play Store - Alpha Testing"
  lane :deploy_alpha do
    json_key_path = ENV["PLAY_JSON_KEY_PATH"] || "play-store-service-account.json"
    json_key_content = File.read(json_key_path) if File.exist?(json_key_path)
    
    upload_to_play_store(
      aab: "app/build/outputs/bundle/prodRelease/app-prod-release.aab",
      track: "alpha",
      json_key: json_key_content,
      package_name: "com.ext.flavourbasedbuildtest",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed",
      changelog: ENV["CHANGELOG"] || "Automated release from CI/CD pipeline"
    )
  end

  desc "Build and deploy to Play Store - Beta Testing"
  lane :deploy_beta do
    json_key_path = ENV["PLAY_JSON_KEY_PATH"] || "play-store-service-account.json"
    json_key_content = File.read(json_key_path) if File.exist?(json_key_path)
    
    upload_to_play_store(
      aab: "../app/build/outputs/bundle/prodRelease/app-prod-release.aab",
      track: "beta",
      json_key: json_key_content,
      package_name: "com.ext.flavourbasedbuildtest",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed",
      changelog: ENV["CHANGELOG"] || "Automated release from CI/CD pipeline"
    )
  end

  desc "Build and deploy to Play Store - Production"
  lane :deploy_production do
    json_key_path = ENV["PLAY_JSON_KEY_PATH"] || "play-store-service-account.json"
    json_key_content = File.read(json_key_path) if File.exist?(json_key_path)
    rollout_percent = ENV["ROLLOUT_PERCENT"] ? ENV["ROLLOUT_PERCENT"].to_f : 1.0
    
    upload_to_play_store(
      aab: "app/build/outputs/bundle/prodRelease/app-prod-release.aab",
      track: "production",
      json_key: json_key_content,
      package_name: "com.ext.flavourbasedbuildtest",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "completed",
      rollout: rollout_percent,
      changelog: ENV["CHANGELOG"] || "Automated release from CI/CD pipeline"
    )
  end

  desc "Build AAB for production flavor"
  lane :build_prod do
    gradle(
      task: "bundle",
      flavor: "prod",
      build_type: "Release"
    )
  end

  desc "Build AAB for staging flavor"
  lane :build_staging do
    gradle(
      task: "bundle",
      flavor: "staging",
      build_type: "Release"
    )
  end

  desc "Build AAB for dev flavor"
  lane :build_dev do
    gradle(
      task: "bundle",
      flavor: "dev",
      build_type: "Release"
    )
  end

  desc "Build and deploy to Play Store (default: internal)"
  lane :deploy do
    build_prod
    deploy_internal
  end

  desc "Supply metadata to Play Store"
  lane :supply_metadata do
    json_key_path = ENV["PLAY_JSON_KEY_PATH"] || "play-store-service-account.json"
    json_key_content = File.read(json_key_path) if File.exist?(json_key_path)
    
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      json_key: json_key_content,
      package_name: "com.ext.flavourbasedbuildtest"
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed with exception: #{exception.message}")
  end
end
